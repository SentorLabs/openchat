# OpenChat — Environment Variables
# Copy this file to .env.local and fill in your values.
# All of these can also be configured at runtime via the Settings UI (/settings).

# ─── Database ─────────────────────────────────────────────────────────────────
# Supported databases: PostgreSQL, MySQL, SQLite
#
# PostgreSQL:
DATABASE_URL=postgresql://postgres:password@localhost:5432/openchat
#
# MySQL:
# DATABASE_URL=mysql://user:password@localhost:3306/openchat
#
# SQLite (file path or :memory:):
# DATABASE_URL=/absolute/path/to/openchat.db
# DATABASE_URL=:memory:

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: openai | anthropic | gemini | ollama
LLM_PROVIDER=openai

# Model name for your chosen provider
# OpenAI:    gpt-4o, gpt-4o-mini, o3-mini
# Anthropic: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
# Gemini:    gemini-2.0-flash, gemini-1.5-pro
# Ollama:    llama3.2, mistral, phi4, gemma3
LLM_MODEL=gpt-4o

# API key for your provider (not required for Ollama)
LLM_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────
# Override the AI's default system prompt
# LLM_SYSTEM_PROMPT="You are a helpful assistant."

# Ollama base URL (only needed if Ollama isn't on localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
